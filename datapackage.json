{
  "name": "afanasiy-nikitin-atlas-data",
  "title": "Afanasiy Nikitin Atlas — open dataset",
  "description": "FAIR data spine for the interactive atlas of Afanasiy Nikitin's 1467-1475 journey (per Khrustalev 2026). Datasets: sources, places, itinerary, people, editions, citations, trade, fragments, calendar. Places & people are reconciled to Wikidata / GeoNames / Pleiades / VIAF (audit: data/reconciliation.md); a Linked Places Format export is data/places.lpf.geojson. The calendar is generated by a reproducible computus script (tools/computus.py). Facts only; see RIGHTS.md.",
  "version": "0.6.0",
  "created": "2026-06-01",
  "keywords": ["digital humanities", "Afanasiy Nikitin", "Khozhenie za tri morya", "historical itinerary", "medieval travel", "linked open data"],
  "licenses": [
    {
      "name": "CC-BY-4.0",
      "title": "Creative Commons Attribution 4.0",
      "path": "https://creativecommons.org/licenses/by/4.0/"
    }
  ],
  "contributors": [
    { "title": "gasyoun", "role": "author", "path": "https://github.com/gasyoun" }
  ],
  "sources": [
    { "title": "Khrustalev D.G. Tetradi kuptsa Afanasiya. SPb.: Nestor-Istoriya, 2026. ISBN 978-5-4469-2357-1", "path": "" },
    { "title": "Khozhenie za tri morya / ed. Lurye & Semenov. L.: Nauka, 1986", "path": "" }
  ],
  "resources": [
    {
      "name": "sources",
      "path": "data/sources.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Source register with rights status",
      "schema": {
        "fields": [
          { "name": "source_id", "type": "string", "description": "Stable key referenced by every other table" },
          { "name": "short", "type": "string", "description": "Short label" },
          { "name": "citation", "type": "string", "description": "Full bibliographic citation" },
          { "name": "type", "type": "string", "description": "monograph | edition | primary-text | dataset | gazetteer | software" },
          { "name": "rights", "type": "string", "description": "in-copyright | public-domain | link-only | CC0 | CC-BY" },
          { "name": "license", "type": "string", "description": "SPDX-style license id where known" },
          { "name": "url", "type": "string", "format": "uri" },
          { "name": "notes", "type": "string", "description": "Rights notes and usage constraints" }
        ],
        "primaryKey": "source_id"
      }
    },
    {
      "name": "places",
      "path": "data/places.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Gazetteer of distinct places (deduplicated)",
      "schema": {
        "fields": [
          { "name": "place_id", "type": "string", "description": "Stable slug" },
          { "name": "name_ru", "type": "string", "description": "Modern Russian name" },
          { "name": "name_historical", "type": "string", "description": "Name as in the text / 15th c." },
          { "name": "name_modern", "type": "string", "description": "Modern place + country" },
          { "name": "country_modern", "type": "string" },
          { "name": "lat", "type": "number", "description": "Latitude, decimal degrees (project localization)" },
          { "name": "lon", "type": "number", "description": "Longitude, decimal degrees (project localization)" },
          { "name": "type", "type": "string", "description": "city | port | capital | region | temple | mine | town | coast | waypoint-group" },
          { "name": "wikidata_qid", "type": "string", "description": "Wikidata QID (Phase 2)" },
          { "name": "pleiades_id", "type": "string", "description": "Pleiades id (Phase 2)" },
          { "name": "geonames_id", "type": "string", "description": "GeoNames id (Phase 2)" },
          { "name": "certainty", "type": "string", "description": "certain | approx | disputed (locational certainty)" },
          { "name": "epistemic", "type": "string", "description": "text | reconstruction | localization | model | hypothesis" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id (identification authority)" },
          { "name": "source_page", "type": "string", "description": "Page reference (to be filled in full Phase 1 pass)" },
          { "name": "notes", "type": "string" },
          { "name": "recon_status", "type": "string", "description": "Phase 2: confirmed | candidate | none | collective | skip-region" }
        ],
        "primaryKey": "place_id",
        "foreignKeys": [
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "itinerary",
      "path": "data/itinerary.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Ordered journey waypoints (29; Kashan/Yazd split — diverges from js/atlas-data.js ATLAS.WP's 28 by design)",
      "schema": {
        "fields": [
          { "name": "seq", "type": "integer", "description": "1-based visit order" },
          { "name": "t_index", "type": "number", "description": "Timeline index from ATLAS.WP (months since April 1467); interpolated for the Kashan/Yazd split" },
          { "name": "place_id", "type": "string", "description": "FK -> places.place_id (repeats allowed: Bidar x2, Hormuz x3, Lar x2)" },
          { "name": "year_label", "type": "string", "description": "Human-readable date label as rendered" },
          { "name": "sea_region", "type": "string", "description": "Which of the three seas / overland leg" },
          { "name": "epistemic", "type": "string", "description": "text | reconstruction | localization | model | hypothesis" },
          { "name": "certainty", "type": "string", "description": "certain | approx | disputed" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id" },
          { "name": "source_page", "type": "string" },
          { "name": "note", "type": "string" }
        ],
        "primaryKey": "seq",
        "foreignKeys": [
          { "fields": "place_id", "reference": { "resource": "places", "fields": "place_id" } },
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "people",
      "path": "data/people.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "People network (helped / harmed / neutral / self / indirect), from afanasy_people_network.html",
      "schema": {
        "fields": [
          { "name": "person_id", "type": "string", "description": "Stable slug" },
          { "name": "name_ru", "type": "string", "description": "Russian name" },
          { "name": "name_translit", "type": "string", "description": "Latin transliteration (aids reconciliation)" },
          { "name": "role", "type": "string", "description": "Role / title" },
          { "name": "relation", "type": "string", "description": "helped | harmed | neutral | self | indirect (relation to Afanasiy)" },
          { "name": "dates", "type": "string", "description": "Life or reign dates where known" },
          { "name": "place_id", "type": "string", "description": "FK -> places.place_id (primary association; nullable)" },
          { "name": "wikidata_qid", "type": "string", "description": "Wikidata QID (Phase 2)" },
          { "name": "viaf_id", "type": "string", "description": "VIAF id (Phase 2)" },
          { "name": "epistemic", "type": "string", "description": "text | reconstruction | localization | model | hypothesis" },
          { "name": "certainty", "type": "string", "description": "certain | approx | disputed" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id" },
          { "name": "source_page", "type": "string" },
          { "name": "notes", "type": "string" },
          { "name": "recon_status", "type": "string", "description": "Phase 2: confirmed | candidate | none | collective" }
        ],
        "primaryKey": "person_id",
        "foreignKeys": [
          { "fields": "place_id", "reference": { "resource": "places", "fields": "place_id" } },
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "editions",
      "path": "data/editions.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Publication history — 9 milestone editions 1818-2026 (from afanasy_editions_v3.html)",
      "schema": {
        "fields": [
          { "name": "edition_id", "type": "string" },
          { "name": "year", "type": "integer" },
          { "name": "editor", "type": "string" },
          { "name": "title", "type": "string" },
          { "name": "place", "type": "string" },
          { "name": "publisher", "type": "string" },
          { "name": "language", "type": "string", "description": "ISO-ish language code; these 9 are all ru" },
          { "name": "kind", "type": "string", "description": "first-publication | first-standalone | first-critical | jubilee | mass-academic | film-tie-in | academic-standard | mass-commercial | reconstruction" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id (ATLAS = project compilation; lu1986=LUR1986, hr2026=KHR2026)" },
          { "name": "source_page", "type": "string" },
          { "name": "notes", "type": "string" }
        ],
        "primaryKey": "edition_id",
        "foreignKeys": [
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "citations",
      "path": "data/citations.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Estimated scholarly attention by decade (epistemic=model — heuristic, not bibliometric)",
      "schema": {
        "fields": [
          { "name": "period", "type": "string", "description": "Decade label" },
          { "name": "total", "type": "integer", "description": "Estimated total = ru + foreign" },
          { "name": "ru", "type": "integer", "description": "Russian scholarship (estimate)" },
          { "name": "foreign", "type": "integer", "description": "Foreign scholarship (estimate)" },
          { "name": "translations", "type": "integer", "description": "Translations (subset)" },
          { "name": "wave", "type": "string", "description": "Named attention wave, if any" },
          { "name": "epistemic", "type": "string", "description": "model (estimated, not real citation counts)" },
          { "name": "certainty", "type": "string", "description": "certain | approx | disputed" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id" },
          { "name": "source_page", "type": "string" },
          { "name": "key_events", "type": "string", "description": "Semicolon-separated milestone events" },
          { "name": "notes", "type": "string" }
        ],
        "primaryKey": "period",
        "foreignKeys": [
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "trade",
      "path": "data/trade.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Trade evidence — 4 text-attributed facts + 19 heuristic model goods (provenance per article_figures/trade_model_sources.md)",
      "schema": {
        "fields": [
          { "name": "item_id", "type": "string" },
          { "name": "item", "type": "string" },
          { "name": "relation_to_nikitin", "type": "string", "description": "yes | no — whether tied to Nikitin's own text" },
          { "name": "value", "type": "number", "description": "Stated value (text items only); blank for model goods" },
          { "name": "unit", "type": "string" },
          { "name": "place_id", "type": "string", "description": "FK -> places.place_id (nullable)" },
          { "name": "model_tier", "type": "string", "description": "Qualitative price-gap tier for model goods" },
          { "name": "basis", "type": "string", "description": "Evidential basis (folio or modelling rationale)" },
          { "name": "epistemic", "type": "string", "description": "text (attested) | model (heuristic comparative)" },
          { "name": "certainty", "type": "string", "description": "certain | approx | disputed" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id" },
          { "name": "source_page", "type": "string" },
          { "name": "notes", "type": "string" }
        ],
        "primaryKey": "item_id",
        "foreignKeys": [
          { "fields": "place_id", "reference": { "resource": "places", "fields": "place_id" } },
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "fragments",
      "path": "data/fragments.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "104 manuscript fragments (Ф.1-104) — metadata only; quote field gated by RIGHTS.md",
      "schema": {
        "fields": [
          { "name": "folio", "type": "integer", "description": "Folio number Ф.N = manuscript (Mamyrev) order" },
          { "name": "chrono_period", "type": "integer", "description": "Khrustalev's chronological writing period (1-7)" },
          { "name": "layer", "type": "string", "description": "Composition block: prayers | dorozhnik_start | dorozhnik_end | marshruttnik | indiyckie_very | war_chronicle | diary | notes" },
          { "name": "genre_ru", "type": "string" },
          { "name": "genre_en", "type": "string" },
          { "name": "loc_ru", "type": "string" },
          { "name": "loc_en", "type": "string" },
          { "name": "date_label_ru", "type": "string" },
          { "name": "date_label_en", "type": "string" },
          { "name": "is_keypoint", "type": "string", "description": "yes if a high-fidelity anchor fragment (13 of 104)" },
          { "name": "quote", "type": "string", "description": "Intentionally empty — gated by RIGHTS.md; per-fragment quotes in the widget are synthetic" },
          { "name": "epistemic", "type": "string", "description": "reconstruction (the composition layering is Khrustalev's model)" },
          { "name": "certainty", "type": "string", "description": "certain | approx | disputed" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id" },
          { "name": "source_page", "type": "string", "description": "Folio reference Ф.N" },
          { "name": "notes", "type": "string" }
        ],
        "primaryKey": "folio",
        "foreignKeys": [
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "calendar",
      "path": "data/calendar.csv",
      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "title": "Computed liturgical / Islamic calendar 1467-1475 (generated by tools/computus.py)",
      "schema": {
        "fields": [
          { "name": "event_id", "type": "string" },
          { "name": "year_ce", "type": "integer" },
          { "name": "type", "type": "string", "description": "pascha | great_lent_start | ramadan_start | eid_al_fitr | mahashivaratri" },
          { "name": "julian_date", "type": "string", "description": "ISO date in the Julian calendar (how Afanasiy reckoned)" },
          { "name": "gregorian_date", "type": "string", "description": "Proleptic Gregorian equivalent" },
          { "name": "hijri", "type": "string" },
          { "name": "method", "type": "string", "description": "Algorithm used, or 'recorded, not recomputed'" },
          { "name": "place_id", "type": "string", "description": "FK -> places.place_id (anchored events; nullable)" },
          { "name": "epistemic", "type": "string", "description": "model (computed) | reconstruction" },
          { "name": "certainty", "type": "string", "description": "certain (exact computus) | approx (tabular / lunisolar)" },
          { "name": "source_id", "type": "string", "description": "FK -> sources.source_id" },
          { "name": "notes", "type": "string" }
        ],
        "primaryKey": "event_id",
        "foreignKeys": [
          { "fields": "place_id", "reference": { "resource": "places", "fields": "place_id" } },
          { "fields": "source_id", "reference": { "resource": "sources", "fields": "source_id" } }
        ]
      }
    },
    {
      "name": "places_lpf",
      "path": "data/places.lpf.geojson",
      "profile": "data-resource",
      "format": "geojson",
      "mediatype": "application/geo+json",
      "encoding": "utf-8",
      "title": "Gazetteer in Linked Places Format (LPF) for the World Historical Gazetteer",
      "description": "GeoJSON-LD; reconciliation IDs (Wikidata / GeoNames / Pleiades) as closeMatch links. Built by tools/build_lpf.py."
    }
  ]
}
